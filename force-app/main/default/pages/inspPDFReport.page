<apex:page standardcontroller="Inspection__c" renderAs="pdf" extensions="inspPDFReportController" showHeader="false" sidebar="false" standardStylesheets="false" applyBodyTag="false" applyHtmlTag="false">
    <html>
        <head>
            <style>
                @page {
                    @top-right {
                        content: element(header-top-right); 
                    }
                    @top-left {
                        content: element(header-top-left); 
                    }
                    @bottom-right {
                        content: element(footer-bottom-right);
                    }
                    @bottom-left {
                        content: element(footer-bottom-left);
                    }
                    @bottom-center {
                        content: element(footer-bottom-center);
                    }
                    margin-top: 5em;
                    size: letter portrait;
                    /* margin-top: 1.0in;
                    margin-bottom: 1.0in;
                    margin-left: 1.0in;
                    margin-right: 1.0in; */
                }
                div.header { }
                div.header-top-right { margin-top: 10px; position: running(header-top-right);  text-align: right; }
                div.header-top-left { margin-top: 10px; position: running(header-top-left);  text-align: left; }
                div.footer {  }
                div.footer-bottom-right { padding-top: 5px; border-top: 1px solid; position: running(footer-bottom-right); text-align: right;}
                div.footer-bottom-center { padding-top: 5px; border-top: 1px solid; position: running(footer-bottom-center); text-align: center;}
                div.footer-bottom-left { padding-top: 5px; border-top: 1px solid; position: running(footer-bottom-left); text-align: left;}
                html, body { font-family: 'Arial Unicode MS'; font-size: 10pt; line-height:15px; }
                /* h1 { font-size: 25pt; } */
                h2 { 
                    /* font-size: 15pt;  */
                    margin-block: 0px !important; } 
                h3 { font-size: 15pt; font-weight: bold; color: navy;}
                .font-color { color: navy;}
                span.w1em { display:inline-block; width: 1em; }
                span.w2em { display:inline-block; width: 2em; }
                .frontPage { font-size: 12pt; }
                .pageLayout td { border-bottom: 1px silver dashed; }
                .section { margin-bottom: 50px; page-break-inside: avoid;  }
                .sectionLast { page-break-inside: avoid; }
                td.noBorder { border-bottom: none; }
                td.pageLabel { width: 25%; color: gray; vertical-align: top; }
                td.pageLabelRight { text-align: right; color: gray; }
                td.pageLabelWide { width: 50%; color: gray; }
                td.pageValue { padding-left: 1em; vertical-align: top; }
                td.score { text-align: right; padding-left: 1em; }
                td.topPadding { padding-top: 2em; }
                .page-break { display:block;page-break-after:always; }
                .pagenumber:before { content: counter(page); }
                .pagecount:before { content: counter(pages); }
                .width50P { width: 50%;}
                .width10P { width: 10%;}
                .width100P { width: 100%;}
                .lineheight30 { line-height:30px; }
                .grey-color { color: gray; }
                .border-style { border-style: silver dashed}
                .tabel-border-style { border-left: none; border-right: none;  border-style: silver}
                .table-bottom-collapse { border-collapse:collapse; }
            </style>
        </head>
        <body>
            <div class="header">
                <div class="header-top-left">
                    <apex:image url="/servlet/servlet.FileDownload?file={!logoId}" width="80%" height="100"
                        rendered="{!NOT(ISBLANK(logoId))}" />
                </div>
                <div class="header-top-right">
                    <apex:image url="{!$Resource.FieldKoLogo}" width="80%"/>
                </div>
            </div>

            <div class="footer">
                <div class="footer-bottom-left">{!Inspection__c.Name}</div>
                <div class="footer-bottom-center">Confidential Information - Do Not Distribute</div>
                <div class="footer-bottom-right">Page <span class="pagenumber"/> of <span class="pagecount"/></div>
            </div>
       
            <apex:pageBlock >
                <h2>Inspection Report</h2>
                <div>Generated by {!$User.FirstName} {!$User.LastName} on &nbsp; <apex:outputText value="{0,date,dd MMMM yyyy 'at' HH:mm:ss}"> <apex:param value="{!NOW() + offset}"/></apex:outputText></div> 
                <br /><br />
                <table style="font-size: 1.1em;font-weight: bold;line-height:30px;">
                    <!-- <tr>
                        <td>Inspection ID:</td> 
                        <td> {!Inspection__c.Name}</td>
                    </tr>
                    <tr>
                        <td>Template Name:</td> 
                        <td> {!Inspection__c.Kinetics__Template__r.Name}</td>
                    </tr>
                    <tr>
                        <td>Account Name:</td>
                        <td>{!Inspection__c.Kinetics__Account__r.Name}</td>
                    </tr>
                    <tr>
                        <td>Contact Name:</td>
                        <td>{!Inspection__c.Kinetics__Contact__r.Name}</td>
                    </tr>
                    <tr>
                        <td><br /></td>
                    </tr>
                    <tr>
                        <td>Inspection Status:</td>
                        <td>{!Inspection__c.Kinetics__Status__c}</td>
                    </tr>
                    <tr>
                        <td>Inspection Score:</td>
                        <td>{!Inspection__c.Kinetics__Score__c} ({!Inspection__c.Kinetics__Percentage_Score__c}%)</td>
                    </tr> -->
                    <apex:repeat value="{!$ObjectType.Inspection__c.FieldSets.Extra_Fields_To_Show_in_PDF}" var="f">
                        <tr>
                            <td>{!f.Label}:</td>
                            <td>{!Inspection__c[f.fieldPath]}</td>
                        </tr>
                    </apex:repeat>
                </table>
                <br /><br />
                <div class="page-break"></div>
                <apex:pageBlock title="Tasks" rendered="{!relatedTaskList.size != 0}" html-style="color: navy;">
                    <apex:pageBlockTable value="{!relatedTaskList}" var="tsk"
                        border="0.3" cellpadding="5px" headerClass="font-color tabel-border-style"
                        styleClass="grey-color table-bottom-collapse width100P" >
                        <apex:column value="{!tsk.Owner.Name}" headervalue="Assigned To" styleClass="tabel-border-style"/>
                        <apex:column value="{!tsk.Subject}" styleClass="tabel-border-style"/>
                        <apex:column value="{!tsk.Description}" styleClass="tabel-border-style"/>
                        <apex:column value="{!tsk.Priority}" styleClass="tabel-border-style"/>
                        <apex:column value="{!tsk.Status}" styleClass="tabel-border-style"/>
                        <apex:column value="{!tsk.ActivityDate}" styleClass="tabel-border-style"/>
                        <apex:column value="{!tsk.Who.Name}" headervalue="Contact Name" styleClass="tabel-border-style"/>
                    </apex:pageBlockTable>
                </apex:pageBlock>

                <div class="page-break"></div>
                <apex:pageBlock title="Notes" rendered="{!contentNoteWrapperList.size != 0}" html-style="color: navy;">
                    <apex:pageBlockTable value="{!contentNoteWrapperList}" var="nt"
                        border="0.3" cellpadding="5px" headerClass="font-color tabel-border-style"
                        styleClass="grey-color table-bottom-collapse width100P">
                        <!-- <apex:column value="{!nt.Title}"/ styleClass="tabel-border-style"> -->
                        <apex:column value="{!nt.createdByUser}" headerValue="User" styleClass="tabel-border-style"/>
                        <apex:column headerValue="Note" styleClass="tabel-border-style">
                            <apex:outputText value="{!nt.contentToDisplay}" escape="false" />    
                        </apex:column>
                    </apex:pageBlockTable>
                </apex:pageBlock>

                <div class="page-break"></div>
                <apex:repeat value="{!sectionDetailsWrapperList}" var="sectionObj">
                    <div class="section width100P">
                        <h2 class="font-color">{!sectionObj.sectionName}</h2>
                        <div style="margin-top: -5px;">{!sectionObj.scoreDetails}</div>
                        <hr />
                        <table class="pageLayout width100P">
                            <tr class="width100P">
                                <td colspan="4" class="noBorder width100P">
                                    <apex:variable var="cnt" value="{!0}" /> 
                                    <table class="nobottom-border-for-last-row width100P">
                                        <apex:repeat value="{!sectionObj.kformAnswersList}" var="ktanswer">
                                            <apex:variable var="cnt" value="{!cnt+1}"/>    
                                            <tr class="width100P">
                                                <td class="pageLabelWide width50P" style="border-bottom: {!IF(cnt == sectionObj.kformAnswersList.size , '0', '')};">
                                                    {!ktanswer.Kinetics__Answer_Index__c}. {!ktanswer.Kinetics__Kinetic_Question__c}
                                                </td>
                                                <td class="pageValue width10P" style="border-bottom: {!IF(cnt == sectionObj.kformAnswersList.size , '0', '')};">
                                                    <!-- <div> <span class="font-color">{!ktanswer.Kinetics__Answer__c}</span> &nbsp;<span style="display: {!IF(ktanswer.Kinetics__Score_Attained__c == null, 'none', 'inline-block')};">({!IF(ktanswer.Kinetics__Score_Attained__c == null, '0', ktanswer.Kinetics__Score_Attained__c)}/{!ktanswer.Kinetics__Out_of_Score__c}) </span></div>  -->
                                                    <div> <span class="font-color">{!ktanswer.Kinetics__Answer__c}</span> &nbsp;<span style="display: {!IF(ktanswer.Kinetics__Answer__c == null, 'none', 'inline-block')};">{!ktanswer.Kinetics__Score__c} </span></div> 
                                                </td>
                                                <apex:repeat value="{!$ObjectType.Kinetic_Form_Answer__c.FieldSets.Extra_Fields_To_Show_In_PDF_Answer_Table}" var="f">
                                                    <td class="pageValue width10P" style="border-bottom: {!IF(cnt == sectionObj.kformAnswersList.size , '0', '')};">
                                                        <apex:outputField value="{!ktanswer[f.fieldPath]}"/>
                                                    </td>
                                                </apex:repeat>
                                            </tr>
                                        </apex:repeat>
                                    </table>
                                </td>
                            </tr>
                        </table> 
                        <hr />
                    </div>
                </apex:repeat>
                
               
                <apex:repeat value="{!fileWrapperListByAnswerId}" var="ansId">           
                    <div class="page-break"></div>
                    <apex:repeat value="{!fileWrapperListByAnswerId[ansId]}" var="fwrapObj">
                        <div class="section width100P">
                            <h2 class="font-color lineheight30">Q{!fwrapObj.questionIndex}. {!fwrapObj.questionDetails}</h2>
                            <div style="margin-top: -5px;">{!fwrapObj.fileTitle}</div>
                            <hr />    
                            <apex:image url="{!fwrapObj.displayURL}" height="400"></apex:image>
                        </div>
                    </apex:repeat>
                </apex:repeat>
                <!-- <apex:repeat value="{!answerRecordList}" var="ansRec">           
                    <div class="page-break"></div>
                        <div class="section width100P">
                            <h2 class="font-color lineheight30">Q{!ansRec.Kinetics__Answer_Index__c}. {!ansRec.Kinetics__Kinetic_Question__c}</h2>
                            <hr />    
                            <apex:outputField value="{!ansRec.Kinetics__Show_More_Information__c}"/>
                        </div>
                </apex:repeat> -->
            </apex:pageBlock>
        </body>
   </html>
</apex:page>